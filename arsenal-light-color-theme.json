  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#B07070", "fontStyle": "italic" }
    },
    {
      "name": "Doc comments",
      "scope": ["comment.block.documentation"],
      "settings": { "foreground": "#A06060", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#CC0005", "fontStyle": "bold" }
    },
    {
      "name": "Import / Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#EF0107" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp"
      ],
      "settings": { "foreground": "#9A7A00" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape", "string.regexp constant.character"],
      "settings": { "foreground": "#B89020" }
    },
    {
      "name": "Template expression",
      "scope": ["punctuation.definition.template-expression"],
      "settings": { "foreground": "#CC0005" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#B86820" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": { "foreground": "#CC3030", "fontStyle": "italic" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": { "foreground": "#9A7A00" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#AA2020" }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.other"
      ],
      "settings": { "foreground": "#8A5020", "fontStyle": "italic" }
    },
    {
      "name": "Classes / Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": { "foreground": "#BB1818", "fontStyle": "bold" }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "keyword.operator.type"
      ],
      "settings": { "foreground": "#9A3030" }
    },
    {
      "name": "Interfaces / Abstract",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": { "foreground": "#883030", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#1A0808" }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": { "foreground": "#6A2828" }
    },
    {
      "name": "Object keys",
      "scope": [
        "meta.objectliteral string.quoted",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#6A2828" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#CC2020" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition",
        "punctuation.separator"
      ],
      "settings": { "foreground": "#A07070" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#9A7A00", "fontStyle": "italic" }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": { "foreground": "#CC0005", "fontStyle": "bold" }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": { "foreground": "#9A7A00" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.selector",
        "meta.selector",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-element.css",
        "entity.other.attribute-name.pseudo-class.css"
      ],
      "settings": { "foreground": "#AA2020" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#6A2828" }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": { "foreground": "#9A7A00" }
    },
    {
      "name": "CSS Units",
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#B86820" }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading"
      ],
      "settings": { "foreground": "#CC0005", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#AA2020", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#9A7A00", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": { "foreground": "#9A7A00", "fontStyle": "underline" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#6A2828", "fontStyle": "" }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "source.json support.type.property-name",
        "source.json meta.structure.dictionary.json string.quoted.double.json"
      ],
      "settings": { "foreground": "#AA2020" }
    },
    {
      "name": "JSON Values",
      "scope": ["source.json string.quoted.double.json"],
      "settings": { "foreground": "#9A7A00" }
    },
    {
      "name": "Python self / cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.parameter.function.language.special.self.python"
      ],
      "settings": { "foreground": "#CC0005", "fontStyle": "italic" }
    },
    {
      "name": "Python builtins",
      "scope": ["support.function.builtin.python"],
      "settings": { "foreground": "#BB1818" }
    },
    {
      "name": "Rust lifetime",
      "scope": ["entity.name.lifetime.rust", "punctuation.definition.lifetime"],
      "settings": { "foreground": "#9A7A00", "fontStyle": "italic" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.illegal", "invalid.deprecated"],
      "settings": { "foreground": "#CC2222", "fontStyle": "strikethrough" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#AA2020",
    "function.declaration": { "foreground": "#AA2020", "bold": true },
    "method": "#BB1818",
    "method.declaration": { "foreground": "#BB1818", "bold": true },
    "class": { "foreground": "#BB1818", "bold": true },
    "class.declaration": { "foreground": "#BB1818", "bold": true },
    "interface": { "foreground": "#883030", "italic": true },
    "enum": { "foreground": "#883030", "italic": true },
    "enumMember": "#9A7A00",
    "type": "#9A3030",
    "typeParameter": { "foreground": "#9A7A00", "italic": true },
    "parameter": { "foreground": "#8A5020", "italic": true },
    "variable": "#1A0808",
    "variable.readonly": "#6A2828",
    "property": "#6A2828",
    "property.readonly": { "foreground": "#6A2828", "italic": true },
    "namespace": "#CC4444",
    "keyword": { "foreground": "#CC0005", "bold": true },
    "string": "#9A7A00",
    "number": "#B86820",
    "regexp": "#9A7A00",
    "operator": "#CC2020",
    "comment": { "foreground": "#B07070", "italic": true },
    "decorator": { "foreground": "#9A7A00", "italic": true },
    "macro": "#BB1818",
    "selfKeyword": { "foreground": "#CC0005", "italic": true },
    "builtinType": "#9A3030",
    "label": "#CC0005"
  }
}
