  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#6B3A3A", "fontStyle": "italic" }
    },
    {
      "name": "Doc comments",
      "scope": ["comment.block.documentation"],
      "settings": { "foreground": "#7A4444", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.cast",
        "keyword.operator.sizeof",
        "keyword.operator.instanceof",
        "keyword.operator.logical.python",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#EF0107", "fontStyle": "bold" }
    },
    {
      "name": "Import / Export",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": { "foreground": "#FF4444" }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.regexp"
      ],
      "settings": { "foreground": "#C5A028" }
    },
    {
      "name": "String escapes",
      "scope": ["constant.character.escape", "string.regexp constant.character"],
      "settings": { "foreground": "#D4B84A" }
    },
    {
      "name": "Template expression",
      "scope": ["punctuation.definition.template-expression"],
      "settings": { "foreground": "#EF0107" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#D4883A" }
    },
    {
      "name": "Boolean / null / undefined",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": { "foreground": "#EF5050", "fontStyle": "italic" }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant"
      ],
      "settings": { "foreground": "#C5A028" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": { "foreground": "#FF8080" }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.other"
      ],
      "settings": { "foreground": "#E8C090", "fontStyle": "italic" }
    },
    {
      "name": "Classes / Types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.name.type.class",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": { "foreground": "#FF9090", "fontStyle": "bold" }
    },
    {
      "name": "Type annotations",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "keyword.operator.type"
      ],
      "settings": { "foreground": "#E8B0B0" }
    },
    {
      "name": "Interfaces / Abstract",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type.enum"
      ],
      "settings": { "foreground": "#D4A0A0", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite"
      ],
      "settings": { "foreground": "#F0E6E6" }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": { "foreground": "#DDB8B8" }
    },
    {
      "name": "Object keys",
      "scope": [
        "meta.objectliteral string.quoted",
        "meta.object-literal.key"
      ],
      "settings": { "foreground": "#DDB8B8" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#EF4040" }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.definition",
        "punctuation.separator"
      ],
      "settings": { "foreground": "#8A5050" }
    },
    {
      "name": "Decorators / Annotations",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": { "foreground": "#C5A028", "fontStyle": "italic" }
    },
    {
      "name": "HTML Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": { "foreground": "#EF0107", "fontStyle": "bold" }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag entity.other.attribute-name"
      ],
      "settings": { "foreground": "#C5A028" }
    },
    {
      "name": "CSS Selectors",
      "scope": [
        "entity.name.selector",
        "meta.selector",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-element.css",
        "entity.other.attribute-name.pseudo-class.css"
      ],
      "settings": { "foreground": "#FF8080" }
    },
    {
      "name": "CSS Properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#DDB8B8" }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": { "foreground": "#C5A028" }
    },
    {
      "name": "CSS Units",
      "scope": ["keyword.other.unit"],
      "settings": { "foreground": "#D4883A" }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading"
      ],
      "settings": { "foreground": "#EF0107", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#FF8080", "fontStyle": "bold" }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#C5A028", "fontStyle": "italic" }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": { "foreground": "#C5A028", "fontStyle": "underline" }
    },
    {
      "name": "Markdown Code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#DDB8B8", "fontStyle": "" }
    },
    {
      "name": "JSON Keys",
      "scope": [
        "source.json support.type.property-name",
        "source.json meta.structure.dictionary.json string.quoted.double.json"
      ],
      "settings": { "foreground": "#FF8080" }
    },
    {
      "name": "JSON Values",
      "scope": ["source.json string.quoted.double.json"],
      "settings": { "foreground": "#C5A028" }
    },
    {
      "name": "Python self / cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.parameter.function.language.special.self.python"
      ],
      "settings": { "foreground": "#EF0107", "fontStyle": "italic" }
    },
    {
      "name": "Python builtins",
      "scope": ["support.function.builtin.python"],
      "settings": { "foreground": "#FF9090" }
    },
    {
      "name": "Rust lifetime",
      "scope": ["entity.name.lifetime.rust", "punctuation.definition.lifetime"],
      "settings": { "foreground": "#C5A028", "fontStyle": "italic" }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": ["invalid", "invalid.illegal", "invalid.deprecated"],
      "settings": { "foreground": "#FF4444", "fontStyle": "strikethrough" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#FF8080",
    "function.declaration": { "foreground": "#FF8080", "bold": true },
    "method": "#FF9090",
    "method.declaration": { "foreground": "#FF9090", "bold": true },
    "class": { "foreground": "#FF9090", "bold": true },
    "class.declaration": { "foreground": "#FF9090", "bold": true },
    "interface": { "foreground": "#D4A0A0", "italic": true },
    "enum": { "foreground": "#D4A0A0", "italic": true },
    "enumMember": "#C5A028",
    "type": "#E8B0B0",
    "typeParameter": { "foreground": "#C5A028", "italic": true },
    "parameter": { "foreground": "#E8C090", "italic": true },
    "variable": "#F0E6E6",
    "variable.readonly": "#DDB8B8",
    "property": "#DDB8B8",
    "property.readonly": { "foreground": "#DDB8B8", "italic": true },
    "namespace": "#EF8080",
    "keyword": { "foreground": "#EF0107", "bold": true },
    "string": "#C5A028",
    "number": "#D4883A",
    "regexp": "#C5A028",
    "operator": "#EF4040",
    "comment": { "foreground": "#6B3A3A", "italic": true },
    "decorator": { "foreground": "#C5A028", "italic": true },
    "macro": "#FF9090",
    "selfKeyword": { "foreground": "#EF0107", "italic": true },
    "builtinType": "#E8B0B0",
    "label": "#EF0107"
  }
}
